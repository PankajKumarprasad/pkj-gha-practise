name: 01 - pkj flask CI wokflow
on: 
    push:
jobs:
    flask-ci-jobs:
        runs-on: ubuntu-latest
        steps:
            - name: Checkout code
              uses: actions/checkout@v6

            - name: Login to Docker Hub
              uses: docker/login-action@v4
              with:
                username: ${{ secrets.DOCKERHUB_USERNAME }}
                password: ${{ secrets.DOCKERHUB_TOKEN }}

            - name: build and push docker image
              uses: docker/build-push-action@v6
              with:
                context: .       #03-actions/
                push: true
                tags: pankaj1204/pkj-flask-app:v1.0

            - name: run container
              run: docker run -d -p 5000:5000 --name pkj-flask-app pankaj1204/pkj-flask-app:v1.0

            - name: check container status
              run: |
                sleep 3
                echo "=== Running Containers ==="
                docker ps -a
                echo "=== Container Logs ==="
                docker logs pankaj1204-flask-app || echo "No logs"
                echo "=== Testing from container ==="
                docker exec pankaj1204-flask-app curl -s http://localhost:5000/health || echo "Failed from container"   
            
            - name: smoke test
              run: |
                 sleep 5 # wait for the container to start
                 curl -v http://localhost:5000 || true   
